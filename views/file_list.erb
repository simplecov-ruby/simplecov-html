<div class="file_list_container" id="<%= to_id(title) %>">
  <span class="group_name hide"><%= title %></span>
  <span class="covered_percent hide"><%= covered_percent(source_files.covered_percent) %></span>

  <div class="file_list--responsive">
    <table class="file_list">
      <thead>
        <tr>
          <th class="cell--left">
            <div class="th-with-filter">
              <span class="th-label">File Name</span>
              <input type="search" class="col-filter col-filter--name" placeholder="Search files&#8230;">
            </div>
          </th>
          <th class="cell--coverage">
            <div class="th-with-filter">
              <span class="th-label">Line Coverage</span>
              <div class="col-filter__coverage">
                <select class="col-filter__op" data-type="line"><option value="lt">&lt;</option><option value="lte" selected>&le;</option><option value="eq">=</option><option value="gte">&ge;</option><option value="gt">&gt;</option></select>
                <input type="number" class="col-filter__value" min="0" max="100" data-type="line" value="100" placeholder="%" step="any">
              </div>
            </div>
          </th>
          <th class="cell--number">Relevant Lines</th>
<%- if branch_coverage? -%>
          <th class="cell--coverage">
            <div class="th-with-filter">
              <span class="th-label">Branch Coverage</span>
              <div class="col-filter__coverage">
                <select class="col-filter__op" data-type="branch"><option value="lt">&lt;</option><option value="lte" selected>&le;</option><option value="eq">=</option><option value="gte">&ge;</option><option value="gt">&gt;</option></select>
                <input type="number" class="col-filter__value" min="0" max="100" data-type="branch" value="100" placeholder="%" step="any">
              </div>
            </div>
          </th>
          <th class="cell--number">Branches</th>
<%- end -%>
<%- if method_coverage? -%>
          <th class="cell--coverage">
            <div class="th-with-filter">
              <span class="th-label">Method Coverage</span>
              <div class="col-filter__coverage">
                <select class="col-filter__op" data-type="method"><option value="lt">&lt;</option><option value="lte" selected>&le;</option><option value="eq">=</option><option value="gte">&ge;</option><option value="gt">&gt;</option></select>
                <input type="number" class="col-filter__value" min="0" max="100" data-type="method" value="100" placeholder="%" step="any">
              </div>
            </div>
          </th>
          <th class="cell--number">Methods</th>
<%- end -%>
        </tr>
<%- line_pct = source_files.lines_of_code > 0 ? source_files.covered_percent : 100.0 -%>
<%- branch_pct = branch_coverage? && source_files.total_branches > 0 ? source_files.branch_covered_percent : 100.0 -%>
<%- method_pct = method_coverage? && source_files.total_methods > 0 ? source_files.method_covered_percent : 100.0 -%>
        <tr class="totals-row">
          <td class="strong t-file-count"><%= source_files.length %> files</td>
          <td class="strong t-totals__line-coverage">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(line_pct) %>" style="width: <%= sprintf("%.1f", line_pct.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(line_pct) %>"><%= sprintf("%.2f", line_pct.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= source_files.covered_lines %>/<%= source_files.lines_of_code %></span>
            </div>
          </td>
          <td class="cell--number"><%= source_files.lines_of_code %></td>
<%- if branch_coverage? -%>
          <td class="strong t-totals__branch-coverage">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(branch_pct) %>" style="width: <%= sprintf("%.1f", branch_pct.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(branch_pct) %>"><%= sprintf("%.2f", branch_pct.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= source_files.covered_branches %>/<%= source_files.total_branches %></span>
            </div>
          </td>
          <td class="cell--number"><%= source_files.total_branches %></td>
<%- end -%>
<%- if method_coverage? -%>
          <td class="strong t-totals__method-coverage">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(method_pct) %>" style="width: <%= sprintf("%.1f", method_pct.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(method_pct) %>"><%= sprintf("%.2f", method_pct.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= source_files.covered_methods %>/<%= source_files.total_methods %></span>
            </div>
          </td>
          <td class="cell--number"><%= source_files.total_methods %></td>
<%- end -%>
        </tr>
      </thead>
      <tbody>
<%- source_files.each do |source_file| -%>
<%- covered_lines = source_file.covered_lines.count; relevant_lines = covered_lines + source_file.missed_lines.count -%>
        <tr class="t-file" data-covered-lines="<%= covered_lines %>" data-relevant-lines="<%= relevant_lines %>"<% if branch_coverage? %> data-covered-branches="<%= source_file.covered_branches.count %>" data-total-branches="<%= source_file.total_branches.count %>"<% end %><% if method_coverage? %> data-covered-methods="<%= source_file.covered_methods.count %>" data-total-methods="<%= source_file.methods.count %>"<% end %>>
          <td class="strong t-file__name"><%= link_to_source_file(source_file) %></td>
          <td class="strong t-file__coverage" data-order="<%= sprintf("%.2f", source_file.covered_percent) %>">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(source_file.covered_percent) %>" style="width: <%= sprintf("%.1f", source_file.covered_percent.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(source_file.covered_percent) %>"><%= sprintf("%.2f", source_file.covered_percent.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= covered_lines %>/<%= relevant_lines %></span>
            </div>
          </td>
          <td class="cell--number"><%= relevant_lines %></td>
<%- if branch_coverage? -%>
          <td class="strong t-file__branch-coverage" data-order="<%= sprintf("%.2f", source_file.branches_coverage_percent) %>">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(source_file.branches_coverage_percent) %>" style="width: <%= sprintf("%.1f", source_file.branches_coverage_percent.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(source_file.branches_coverage_percent) %>"><%= sprintf("%.2f", source_file.branches_coverage_percent.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= source_file.covered_branches.count %>/<%= source_file.total_branches.count %></span>
            </div>
          </td>
          <td class="cell--number"><%= source_file.total_branches.count %></td>
<%- end -%>
<%- if method_coverage? -%>
          <td class="strong t-file__method-coverage" data-order="<%= sprintf("%.2f", source_file.methods_coverage_percent) %>">
            <div class="coverage-cell">
              <div class="coverage-bar">
                <div class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(source_file.methods_coverage_percent) %>" style="width: <%= sprintf("%.1f", source_file.methods_coverage_percent.floor(1)) %>%"></div>
              </div>
              <span class="coverage-cell__pct <%= coverage_css_class(source_file.methods_coverage_percent) %>"><%= sprintf("%.2f", source_file.methods_coverage_percent.floor(2)) %>%</span>
              <span class="coverage-cell__fraction"><%= source_file.covered_methods.count %>/<%= source_file.methods.count %></span>
            </div>
          </td>
          <td class="cell--number"><%= source_file.methods.count %></td>
<%- end -%>
        </tr>
<%- end -%>
      </tbody>
    </table>
  </div>
</div>
