<div class="file_list_container" id="<%= to_id(title) %>">
  <h2>
    <span class="group_name"><%= title %></span>
    &mdash;
    <span class="covered_percent"><%= covered_percent(source_files.covered_percent) %></span>
  </h2>

  <a name="<%= to_id(title) %>"></a>

  <div class="summary-stats">
    <div class="t-line-summary">
      <b><%= source_files.length %></b> files,
      <b><%= source_files.lines_of_code %></b> relevant lines:
      <span class="green"><b><%= source_files.covered_lines %></b> covered</span>,
      <span class="red"><b><%= source_files.missed_lines %></b> missed</span>
    </div>
<%- if branch_coverage? -%>
    <div class="t-branch-summary">
      <b><%= source_files.total_branches %></b> branches:
      <span class="green"><b><%= source_files.covered_branches %></b> covered</span>,
      <span class="red"><b><%= source_files.missed_branches %></b> missed</span>
    </div>
<%- end -%>
<%- if method_coverage? -%>
    <div class="t-method-summary">
      <b><%= source_files.total_methods %></b> methods:
      <span class="green"><b><%= source_files.covered_methods %></b> covered</span>,
      <span class="red"><b><%= source_files.missed_methods %></b> missed</span>
    </div>
<%- end -%>
  </div>

  <div class="file_list--responsive">
    <table class="file_list">
      <thead>
        <tr>
          <th>File</th>
          <th class="cell--number">Coverage</th>
          <th class="cell--number">Lines</th>
          <th class="cell--number">Relevant</th>
          <th class="cell--number">Covered</th>
          <th class="cell--number">Missed</th>
          <th class="cell--number">Hits/Line</th>
<%- if branch_coverage? -%>
          <th class="cell--number">Branches</th>
          <th class="cell--number">Total</th>
          <th class="cell--number">Covered</th>
          <th class="cell--number">Missed</th>
<%- end -%>
<%- if method_coverage? -%>
          <th class="cell--number">Methods</th>
          <th class="cell--number">Total</th>
          <th class="cell--number">Covered</th>
          <th class="cell--number">Missed</th>
<%- end -%>
        </tr>
      </thead>
      <tbody>
<%- source_files.each do |source_file| -%>
        <tr class="t-file">
          <td class="strong t-file__name"><%= link_to_source_file(source_file) %></td>
          <td class="strong cell--number t-file__coverage">
            <div class="coverage-bar">
              <span class="<%= coverage_css_class(source_file.covered_percent) %>"><%= sprintf("%.2f", source_file.covered_percent.floor(2)) %>%</span>
              <span class="coverage-bar__track">
                <span class="coverage-bar__fill coverage-bar__fill--<%= coverage_css_class(source_file.covered_percent) %>" style="width: <%= sprintf("%.1f", source_file.covered_percent.floor(1)) %>%"></span>
              </span>
            </div>
          </td>
          <td class="cell--number"><%= source_file.lines.count %></td>
          <td class="cell--number"><%= source_file.covered_lines.count + source_file.missed_lines.count %></td>
          <td class="cell--number"><%= source_file.covered_lines.count %></td>
          <td class="cell--number"><%= source_file.missed_lines.count %></td>
          <td class="cell--number"><%= sprintf("%.2f", source_file.covered_strength) %></td>
<%- if branch_coverage? -%>
          <td class="strong cell--number t-file__branch-coverage"><%= covered_percent(source_file.branches_coverage_percent) %></td>
          <td class="cell--number"><%= source_file.total_branches.count %></td>
          <td class="cell--number"><%= source_file.covered_branches.count %></td>
          <td class="cell--number"><%= source_file.missed_branches.count %></td>
<%- end -%>
<%- if method_coverage? -%>
          <td class="strong cell--number t-file__method-coverage"><%= covered_percent(source_file.methods_coverage_percent) %></td>
          <td class="cell--number"><%= source_file.methods.count %></td>
          <td class="cell--number"><%= source_file.covered_methods.count %></td>
          <td class="cell--number"><%= source_file.missed_methods.count %></td>
<%- end -%>
        </tr>
<%- end -%>
      </tbody>
    </table>
  </div>
</div>
